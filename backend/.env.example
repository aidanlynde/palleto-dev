APP_ENV=development
APP_NAME=Palleto API
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:19006,http://localhost:8081
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/palleto

# Firebase Admin. Use either FIREBASE_CREDENTIALS_PATH or the individual values below.
FIREBASE_CREDENTIALS_PATH=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# OpenAI vision card generation. If OPENAI_API_KEY is empty, backend falls back to placeholder generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
