{
  "rewrites": [
    {
      "source": "/s/:token",
      "destination": "/api/share?token=:token"
    },
    {
      "source": "/og/share/:token.png",
      "destination": "/api/share-image?token=:token"
    },
    {
      "source": "/share/card/:token.png",
      "destination": "/api/share-card-image?token=:token"
    }
  ]
}
