{
  "expo": {
    "name": "Palleto",
    "slug": "palleto",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "palleto",
    "icon": "./assets/app-icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/brand/palleto-logo-transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "com.palleto.palletolabs",
      "googleServicesFile": "./GoogleService-Info.plist",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.palleto.palletolabs",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      }
    },
    "extra": {
      "apiBaseUrl": "https://palleto-dev-production.up.railway.app",
      "eas": {
        "projectId": "7b72700e-faef-43ab-854e-4c00ae64e718"
      }
    },
    "owner": "aidanlynde",
    "plugins": [
      "expo-asset",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Palleto uses the camera to capture real-world inspiration.",
          "photosPermission": "Palleto uses your photo library to turn saved references into inspiration cards."
        }
      ],
      "expo-font",
      "expo-video"
    ]
  }
}
